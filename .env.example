# Database connection
DATABASE_URL=postgresql://alphorn:alphorn@localhost:5432/alphorn

# Used by docker-compose.yml to set the Postgres password for both the db
# service and DATABASE_URL. Ignored when running outside docker compose.
# POSTGRES_PASSWORD=alphorn

# Better Auth
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-string
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (via Microsoft Entra ID / Azure AD)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common  # GUID for single-tenant, or "common", "organizations", "consumers"

# Custom OIDC provider (e.g., Keycloak, Okta, Azure AD / Microsoft Entra ID)
# Set OIDC_CLIENT_ID to enable. Use either OIDC_DISCOVERY_URL (recommended)
# or set the individual endpoint URLs manually.
# OIDC_PROVIDER_ID=custom-oidc
# OIDC_PROVIDER_NAME=SSO
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_DISCOVERY_URL=https://login.microsoftonline.com/{tenant}/v2.0/.well-known/openid-configuration
# OIDC_AUTHORIZATION_URL=
# OIDC_TOKEN_URL=
# OIDC_USERINFO_URL=
# OIDC_SCOPES=openid profile email
# OIDC_PKCE=false

# Optional: Database connection pool size (default: 10)
# DATABASE_POOL_SIZE=10

# Optional: Run mode (all | web | worker)
# MODE=all

# Optional: Worker concurrency (default: 20)
# WORKER_CONCURRENCY=20

# Optional: Log level (default: info)
# LOG_LEVEL=info  # trace, debug, info, warn, error, fatal

# Optional: Better Auth internal log level (default: warn)
# BETTER_AUTH_LOG_LEVEL=warn  # debug, info, warn, error

# System email (SMTP) — optional
# Required for email verification, password reset, and email invitations.
# Without these, users can sign up without verifying and invitations are link-only.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Alphorn <noreply@example.com>

# SSE standalone server — optional
# By default, SSE connections are handled in-process by the web server.
# Set SSE_MODE=standalone to run a dedicated SSE server (recommended for
# multi-instance deployments where SSE connections must be pinned to one process).
# SSE_MODE=standalone
# SSE_PORT=4000
# SSE_SERVER_URL=http://localhost:4000
# SSE_INTERNAL_SECRET=change-me-to-a-random-string

# Optional: Error tracking (Sentry / GlitchTip)
# Works with Sentry and any Sentry-compatible server (e.g., GlitchTip).
# These three values are also exposed to the browser bundle automatically
# (via next.config.ts) — no need to set NEXT_PUBLIC_SENTRY_* separately.
# SENTRY_DSN=https://key@sentry.example.com/1
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional: App version shown in the UI and /api/health response.
# If unset, next.config.ts falls back to the current git SHA, then to "dev".
# APP_VERSION=1.0.0

# Optional: Egress proxy for outbound HTTP(S) from channel deliveries.
# Routes all fetch() calls through an SSRF-aware proxy (e.g. stripe/smokescreen).
# See docker-compose.secure.yml for a ready-to-use smokescreen sidecar.
# EGRESS_PROXY_URL=http://smokescreen:4750

# Optional: Maximum body size (bytes) accepted on the public webhook receiver.
# Oversized requests are rejected with HTTP 413 before parsing.
# WEBHOOK_MAX_BODY_BYTES=1048576

# Optional: Maximum webhook forwarding hops before a request is rejected with
# HTTP 508 Loop Detected. Alphorn signs X-Alphorn-Hops / X-Alphorn-Trace
# headers on outbound webhook-channel calls so it can break cycles that route
# through external services. Default 3. Raise only if you have a legitimate
# multi-hop forwarding chain.
# WEBHOOK_MAX_HOPS=3

# Optional: SSE connection caps. Protect the SSE endpoint against exhaustion by
# a single client or subscriber flood on a leaked publicId.
# SSE_MAX_CONNECTIONS_PER_CHANNEL=20
# SSE_MAX_CONNECTIONS_PER_IP=20
